# Default behaviour — let Git detect text files and normalize line endings
* text=auto

# Force LF for source and config files
*.java       text eol=lf
*.xml        text eol=lf
*.md         text eol=lf
*.properties text eol=lf
*.yml        text eol=lf
*.yaml       text eol=lf
*.txt        text eol=lf
*.csv        text eol=lf
*.html       text eol=lf
*.json       text eol=lf

# Binary files — no conversion
*.jar        binary
*.class      binary
*.png        binary
*.jpg        binary
*.jpeg       binary
*.gif        binary
*.ico        binary
